# ── Strike Finance (https://www.strikefinance.org) ──────────────────────────
# Market data (live price + chart) works with NONE of these set.
# Connecting a wallet + placing orders requires STRIKE_BUILDER_CODE.

# Optional. Defaults to https://api.strikefinance.org
STRIKE_API_BASE=https://api.strikefinance.org

# REQUIRED to connect a wallet and trade. Obtain a builder code from Strike.
STRIKE_BUILDER_CODE=your_strike_builder_code

# Optional builder fee charged on each order, in basis points (0-100). Default 0.
STRIKE_DEFAULT_FEE_BPS=0

# Signs the wallet session cookie AND encrypts the stored Strike API-wallet
# secret key at rest. Use a random 32+ character string. REQUIRED for trading.
STRIKE_WALLET_SESSION_SECRET=change-me-to-a-random-32-plus-character-secret
